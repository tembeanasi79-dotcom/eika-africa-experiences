# .env.example

# Google Analytics 4
# Get your ID from: https://analytics.google.com
# Navigate to: Admin → Property → Data Streams → Web → Measurement ID
VITE_GTAG_ID=G-XXXXXXXXXX

# Google Ads Conversion Tracking (Optional)
# Get your ID from: https://ads.google.com
# Navigate to: Tools & Settings → Conversions → Your Conversion ID
VITE_CONVERSION_ID=AW-XXXXXXXXXX

# PostHog Analytics
# Get your key from: https://app.posthog.com
# Navigate to: Project Settings → API Keys
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking (if needed)
# VITE_SENTRY_DSN=your_sentry_dsn_here

# Google reCAPTCHA
# Get your key from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Supabase (for backend services)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here
